# Tableau Server credentials
# Create a Personal Access Token in your Tableau Server account settings
TABLEAU_SERVER_URL=https://your-tableau-server.com
TABLEAU_SITE_NAME=your-site-name
TABLEAU_TOKEN_NAME=your-token-name
TABLEAU_TOKEN_SECRET=your-token-secret

# Trello credentials for change request tracking
# Get API key from: https://trello.com/power-ups/admin
# Get token: https://trello.com/1/authorize?key=YOUR_KEY&name=ReportTracker&scope=read,write&expiration=never&response_type=token
TRELLO_API_KEY=your-api-key
TRELLO_TOKEN=your-token
TRELLO_BOARD_NAME=The Report Report
TRELLO_LIST_NAME=Change Request Queue
